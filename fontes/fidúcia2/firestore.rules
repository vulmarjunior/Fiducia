rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ----- Primitives -----
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ----- Validation helpers (Pillar 2: Validation Blueprints) -----

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'createdAt']) && data.keys().size() == 3
        && data.email is string && data.email.size() <= 100
        && data.name is string && data.name.size() <= 150
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'balance', 'createdAt']) 
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.type in ['checking', 'savings', 'wallet']
        && data.balance is number
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidCreditCard(data) {
      return data.keys().hasAll(['userId', 'name', 'limit', 'closingDay', 'dueDay', 'createdAt'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.limit is number && data.limit >= 0
        && data.closingDay is int && data.closingDay >= 1 && data.closingDay <= 28
        && data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 28
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'icon', 'isDefault', 'createdAt'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.type in ['income', 'expense']
        && data.icon is string && data.icon.size() <= 50
        && data.isDefault is bool
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'date', 'description', 'status', 'createdAt'])
        && data.userId == request.auth.uid
        && data.type in ['income', 'expense', 'transfer', 'receita', 'despesa', 'transferencia']
        && data.amount is number && data.amount >= 0
        && data.date is string && data.date.size() <= 50
        && data.description is string && data.description.size() <= 200
        && data.status in ['paid', 'pending', 'cancelled', 'pago', 'pendente', 'cancelado', 'realizado']
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['userId', 'name', 'targetAmount', 'currentAmount', 'createdAt'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 150
        && data.targetAmount is number && data.targetAmount >= 0
        && data.currentAmount is number && data.currentAmount >= 0
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['userId', 'categoryId', 'amount', 'period', 'createdAt'])
        && data.userId == request.auth.uid
        && data.categoryId is string && data.categoryId.size() <= 50
        && data.amount is number && data.amount >= 0
        && data.period == 'monthly'
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(['userId', 'cardId', 'period', 'status'])
        && data.userId == request.auth.uid
        && data.cardId is string && data.cardId.size() <= 50
        && data.period is string && data.period.size() == 7
        && data.status in ['aberta', 'fechada', 'paga'];
    }

    // ----- Rules Matches -----

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().email == existing().email 
                     && incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }

    // Accounts Collection
    match /accounts/{accountId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Credit Cards Collection
    match /creditCards/{cardId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Transactions Collection
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Budgets Collection
    match /budgets/{budgetId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Goals Collection
    match /goals/{goalId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Invoices Collection
    match /invoices/{invoiceId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Closed Periods Collection
    match /closedPeriods/{periodId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Tags Collection
    match /tags/{tagId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Activity Logs Collection
    match /activityLogs/{logId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

  }
}
